{
  "apiKeyHelper": "~/.claude/api-key-helper.sh",
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/stamp.sh",
            "statusMessage": "Stamping file with version/date..."
          },
          {
            "type": "command",
            "command": "input=$(cat); f=$(echo \"$input\" | jq -r '.tool_input.file_path // \"\"'); proj=$(echo \"$f\" | grep -oP '$HOME/claude/projects/[^/]+'); if [ -n \"$proj\" ] && ! echo \"$f\" | grep -q 'INSTRUCTIONS_' && ! echo \"$f\" | grep -q 'CLAUDE.md'; then proj_name=$(basename \"$proj\"); echo \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"PostToolUse\\\",\\\"additionalContext\\\":\\\"REMINDER: You just modified a file in the $proj_name project. You MUST now update $proj/INSTRUCTIONS_${proj_name}.txt (every change) and bump its Last updated date. If you changed any design constraints, invariants, or key rules, ALSO update $proj/CLAUDE.md.\\\"}}\"; fi",
            "statusMessage": "Checking project INSTRUCTIONS + CLAUDE.md sync..."
          },
          {
            "type": "command",
            "command": "input=$(cat); f=$(echo \"$input\" | jq -r '.tool_input.file_path // \"\"'); if [ \"$f\" = \"$HOME/claude/projects/tmux-studio/tmux_studio.py\" ]; then cp $HOME/claude/projects/tmux-studio/tmux_studio.py $HOME/.tmux-studio/tmux_studio.py; fi 2>/dev/null || true",
            "statusMessage": "Deploying tmux_studio.py..."
          },
          {
            "type": "command",
            "command": "input=$(cat); f=$(echo \"$input\" | jq -r '.tool_input.file_path // \"\"'); proj=$HOME/claude/projects/tmux.conf; if echo \"$f\" | grep -q \"$proj/\"; then case \"$f\" in */tmux.conf) cp \"$proj/tmux.conf\" ~/.tmux/tmux.conf && tmux source-file ~/.tmux/tmux.conf ;; */themes/light.conf) mkdir -p ~/.tmux/themes && cp \"$proj/themes/light.conf\" ~/.tmux/themes/light.conf ;; */themes/dark.conf) mkdir -p ~/.tmux/themes && cp \"$proj/themes/dark.conf\" ~/.tmux/themes/dark.conf ;; */tmux_broadcast.sh) cp \"$proj/tmux_broadcast.sh\" ~/.tmux/tmux_broadcast.sh && chmod +x ~/.tmux/tmux_broadcast.sh ;; */tmux_click.sh) cp \"$proj/tmux_click.sh\" ~/.tmux/tmux_click.sh && chmod +x ~/.tmux/tmux_click.sh ;; esac; fi 2>/dev/null || true",
            "statusMessage": "Deploying tmux.conf project file..."
          },
          {
            "type": "command",
            "command": "input=$(cat); f=$(echo \"$input\" | jq -r '.tool_input.file_path // \"\"'); if [ \"$f\" = \"$HOME/claude/projects/bashrc_bus-home/.bashrc\" ]; then cp $HOME/claude/projects/bashrc_bus-home/.bashrc $HOME/.bashrc; fi 2>/dev/null || true",
            "statusMessage": "Deploying .bashrc..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/topoassist-pytest-check.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/topoassist-gas-test-check.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/settings-backup.sh",
            "statusMessage": "Syncing settings backup and committing..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/project-commands-sync.sh",
            "statusMessage": "Syncing project command to global..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/topoassist-userguide-check.sh",
            "statusMessage": "Checking if UserGuide.html needs updating..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/topoassist-deploy-tracker.sh",
            "statusMessage": "Checking TopoAssist deploy status..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/post-change-summary.sh",
            "statusMessage": "Building change summary..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/rollback-logger.sh",
            "statusMessage": "Checking for revert/rollback to log..."
          }
        ]
      },
      {
        "matcher": "mcp__winnow__",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/winnow-auth-check.sh",
            "statusMessage": "Checking Winnow response for auth failures..."
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      },
      {
        "matcher": "mcp__winnow__",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/winnow-auth-check.sh",
            "statusMessage": "Winnow tool failure — checking auth..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); f=$(echo \"$input\" | jq -r '.tool_input.file_path // \"\"'); content=$(echo \"$input\" | jq -r '.tool_input.content // .tool_input.new_string // \"\"'); if [ -n \"$content\" ]; then ext=\"${f##*.}\"; issues=\"\"; sec=$(echo \"$content\" | grep -icE '(password|secret|api_key|apikey|token|auth_token)\\s*=' 2>/dev/null); [ \"${sec:-0}\" -gt 0 ] && issues=\"$issues [POSSIBLE_SECRETS:$sec]\"; skip_debug=0; case \"$ext\" in md|txt|json|yaml|yml|toml) skip_debug=1 ;; esac; echo \"$f\" | grep -q '/.claude/hooks/' && skip_debug=1; if [ \"$skip_debug\" -eq 0 ]; then dbg=$(echo \"$content\" | grep -cE 'console\\.(log|debug|warn|error)\\(|debugger;|pdb\\.set_trace|breakpoint\\(\\)|var_dump\\(' 2>/dev/null); todo=$(echo \"$content\" | grep -cE '\\b(TODO|FIXME|HACK|XXX)\\b' 2>/dev/null); [ \"${dbg:-0}\" -gt 0 ] && issues=\"$issues [DEBUG_STATEMENTS:$dbg]\"; [ \"${todo:-0}\" -gt 0 ] && issues=\"$issues [UNRESOLVED_TODOS:$todo]\"; fi; if [ -n \"$issues\" ]; then echo \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"PreToolUse\\\",\\\"additionalContext\\\":\\\"PRE-WRITE SCAN FAILED:$issues — fix these before writing this file.\\\"}}\"; fi; fi",
            "statusMessage": "Scanning content for debug code, secrets, TODOs..."
          },
          {
            "type": "command",
            "command": "input=$(cat); f=$(echo \"$input\" | jq -r '.tool_input.file_path // \"\"'); if [ -n \"$f\" ] && [ -f \"$f\" ] && echo \"$f\" | grep -q '$HOME/claude/projects/'; then if ! git -C \"$(dirname \"$f\")\" rev-parse --git-dir > /dev/null 2>&1; then proj=$(echo \"$f\" | grep -oP '$HOME/claude/projects/[^/]+'); bdir=\"$proj/.claude/backups\"; mkdir -p \"$bdir\"; ts=$(date +%Y%m%d_%H%M%S); fname=$(basename \"$f\"); cp \"$f\" \"$bdir/${fname}.${ts}.bak\" && echo \"{\\\"hookSpecificOutput\\\":{\\\"hookEventName\\\":\\\"PreToolUse\\\",\\\"additionalContext\\\":\\\"[WARNING] $(basename $proj) has no git repo — this project is unprotected. Run: git init $proj && git -C $proj add -A && git -C $proj commit -m 'Initial commit'. Backup created: .claude/backups/${fname}.${ts}.bak\\\"}}\"; fi; fi",
            "statusMessage": "Backing up file before edit (non-git project)..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/commit-guard.sh",
            "statusMessage": "Scanning staged diff before commit..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/prompt-secrets-scan.sh",
            "statusMessage": "Scanning prompt for secrets..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/settings-drift-check.sh",
            "statusMessage": "Checking for external settings changes..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/git-uncommitted-check.sh",
            "statusMessage": "Checking for uncommitted changes..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/post-change-summary.sh",
            "statusMessage": "Checking for uncommitted changes after skill completion..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {},
  "autoUpdatesChannel": "stable",
  "skipAutoPermissionPrompt": true
}
